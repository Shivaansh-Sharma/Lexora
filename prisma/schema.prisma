generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnalysisType {
  SENTIMENT
  EMOTION
  NER
  SUMMARY
  KEYWORDS
  TOPIC
  READABILITY
  AI_DETECTION
  LANGUAGE
  GRAMMAR
  PLAGIARISM
  COMPARISON
}

model User {

  id        String   @id @default(cuid())

  email     String   @unique

  password  String

  name      String?

  createdAt DateTime @default(now())

  analyses  Analysis[]

  comparisons Comparison[]
}

model Analysis {
  id          String   @id @default(cuid())

  userId      String
  type        AnalysisType

  inputText   String   @db.Text
  result      Json

  language    String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Comparison {
  id        String   @id @default(cuid())

  userId    String

  text1     String   @db.Text
  text2     String   @db.Text

  result    Json

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
} 